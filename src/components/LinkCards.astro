---
const cards = [
  {
    href: "https://magic-ingredient.enginyyr.com",
    title: "Magic Ingredient",
    description:
      "AI-powered workflow automation for small businesses. Transform tedious tasks into streamlined processes.",
    accent: "#ef4444",
  },
  {
    href: "https://grove.enginyyr.com",
    title: "Grove",
    description:
      "An AI orchestration runtime for small builders. Multi-tenant, durable, and schedulable in a single binary.",
    accent: "#0d9488",
  },
  {
    href: "https://www.facebook.com/magicingredient7",
    title: "Magic Ingredient on Facebook",
    description:
      "Follow Magic Ingredient on Facebook for updates, tips, and community.",
    accent: "#1877f2",
  },
  {
    href: "https://trailhead.enginyyr.com",
    title: "Trailhead",
    description:
      "A retrieval-augmented generation (RAG) solution for intelligent document search and knowledge extraction.",
    accent: "#228b22",
  },
  {
    href: "https://learncanopy.com/",
    title: "Canopy",
    description:
      "Learn smarter with AI-powered education tools designed to help you grow.",
    accent: "#22c55e",
  },
  {
    href: "https://orbit.llm-games.com",
    title: "Orbit",
    description:
      "A daily word game where you guess words based on semantic meaning. How close can you get?",
    accent: "#7c3aed",
  },
];
---

<section id="links" class="links-section">
  <h2>Out in the Wild</h2>
  <div class="link-grid">
    {
      cards.map(card => (
        <a
          href={card.href}
          target="_blank"
          rel="noopener noreferrer"
          class="link-card"
          style={`--accent: ${card.accent}`}
        >
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .links-section {
    @apply pb-6 pt-12;
  }
  .links-section h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .link-grid {
    @apply mt-6 grid gap-4;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .link-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .link-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .link-card {
    position: relative;
    display: block;
    padding: 1.1rem 1.25rem 1.1rem 1.5rem;
    border-radius: 0.625rem;
    background: rgba(var(--color-card), 0.45);
    text-decoration: none;
    overflow: hidden;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease;
  }
  .link-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--accent);
  }
  .link-card:hover {
    transform: translateY(-2px);
    background: rgba(var(--color-card), 0.8);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
  }
  .link-card h3 {
    font-style: normal;
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .link-card p {
    margin: 0.4rem 0 0 0;
    font-size: 0.85rem;
    line-height: 1.5;
    opacity: 0.78;
  }
</style>
