---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div">;

const { ...attrs } = Astro.props;
---

<div {...attrs}>
  <slot />
</div>

<script>
  import mermaid from "mermaid";

  function renderMermaid() {
    const theme = localStorage.getItem("theme") || "forest";
    mermaid.initialize({
      startOnLoad: false,
      theme: theme === "dark" ? "dark" : "forest",
    });

    document.querySelectorAll('pre[lang="mermaid-client"]').forEach(async (el, i) => {
      if (el.getAttribute("data-processed")) {
        return;
      }
      
      const chart = el.querySelector('code')?.innerText;
      
      if (!chart) return;

      const { svg } = await mermaid.render(`mermaid-svg-${i}`, chart);

      const container = document.createElement("div");
      container.innerHTML = svg;
      container.classList.add("mermaid-container");
      
      el.replaceWith(container);
    });
  }

  // Initial render
  renderMermaid();

  // Re-render on theme change
  document.addEventListener("theme-change", renderMermaid);

  // Re-render on Astro's after-swap event (for view transitions)
  document.addEventListener("astro:after-swap", renderMermaid);
</script>

<style>
.mermaid-container {
  @apply overflow-x-auto my-4 p-4 rounded-lg;
  background-color: var(--card-bg);
}
</style>